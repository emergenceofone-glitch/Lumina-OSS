{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID"
        },
        "email": {
          "type": "string",
          "description": "The user's email address"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name"
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp of user creation"
        }
      },
      "required": ["uid", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The ID of the user who owns this message"
        },
        "role": {
          "type": "string",
          "description": "The role of the sender (user or ai)",
          "enum": ["user", "ai"]
        },
        "text": {
          "type": "string",
          "description": "The message content"
        },
        "timestamp": {
          "type": "number",
          "description": "When the message was sent"
        }
      },
      "required": ["uid", "role", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat history for a user"
    }
  }
}
