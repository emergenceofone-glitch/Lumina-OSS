rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function hasOnlyAllowedFields(data, fields) {
      return data.keys().hasOnly(fields);
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasOnlyAllowedFields(data, ['uid', 'email', 'displayName', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.uid is string && data.uid.size() > 0 &&
             (!('email' in data) || (data.email is string && data.email.size() < 256)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 128)) &&
             data.createdAt is number;
    }

    function isValidMessage(data) {
      return hasOnlyAllowedFields(data, ['uid', 'role', 'text', 'timestamp', 'media', 'hasFiles']) &&
             data.uid == request.auth.uid &&
             data.uid is string &&
             data.role in ['user', 'ai'] &&
             data.text is string && data.text.size() <= 20000 &&
             data.timestamp is number &&
             (!('media' in data) || (data.media == null || (data.media is string && data.media.size() < 2000000))) &&
             (!('hasFiles' in data) || data.hasFiles is bool);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                     request.resource.data.createdAt == resource.data.createdAt;
      
      match /messages/{messageId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMessage(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
